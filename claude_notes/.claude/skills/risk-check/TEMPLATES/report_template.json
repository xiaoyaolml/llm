      "priority": "low",
      "tasks": [
        {
          "id": 3,
          "description": "{{task_description}}",
          "owner": "{{owner}}",
          "estimated_time_hours": {{time_estimate}},
          "impact": "{{impact_description}}",
          "validation_method": "{{validation_method}}"
        }
      ]
    }
  },
  "validation_plan": {
    "numerical_tests": [
      {
        "test_name": "Precision Test",
        "command": "./precision_test --tolerance 1e-6 --iterations 1000",
        "success_criteria": "All calculations within 1e-6 tolerance",
        "metrics_to_collect": ["max_error", "mean_error", "std_error"]
      },
      {
        "test_name": "Stability Test",
        "command": "./stability_test --extreme-values --boundary-conditions",
        "success_criteria": "No crashes or NaN values under extreme conditions",
        "metrics_to_collect": ["crash_count", "nan_count", "inf_count"]
      },
      {
        "test_name": "Convergence Test",
        "command": "./convergence_test --max-paths 100000 --tolerance 1e-4",
        "success_criteria": "Monte Carlo estimates converge within 1e-4 tolerance",
        "metrics_to_collect": ["convergence_rate", "final_error", "confidence_interval"]
      }
    ],
    "statistical_tests": [
      {
        "test_name": "VaR Backtest",
        "test_case": "TEST_F(RiskTest, VaRBacktest)",
        "success_criteria": "EXPECT_TRUE(results.is_valid)",
        "description": "Validate VaR model accuracy using historical data"
      },
      {
        "test_name": "Monte Carlo Convergence",
        "test_case": "TEST_F(MonteCarloTest, Convergence)",
        "success_criteria": "EXPECT_NEAR(estimate_10k, estimate_100k, 1e-3)",
        "description": "Verify Monte Carlo estimates converge with increasing paths"
      }
    ],
    "business_tests": [
      {
        "test_name": "Basel III Compliance",
        "test_case": "TEST_F(ComplianceTest, BaselIIIRequirements)",
        "success_criteria": "EXPECT_GE(capital_requirement, minimum_capital_ratio * risk_weighted_assets)",
        "description": "Ensure risk calculations meet Basel III capital requirements"
      },
      {
        "test_name": "Financial Crisis Stress Test",
        "test_case": "TEST_F(StressTest, FinancialCrisis2008)",
        "success_criteria": "EXPECT_LE(losses, maximum_acceptable_loss)",
        "description": "Test portfolio resilience under 2008 financial crisis conditions"
      }
    ]
  },
  "recommendations": {
    "immediate_actions": [
      "{{immediate_action_1}}",
      "{{immediate_action_2}}",
      "{{immediate_action_3}}"
    ],
